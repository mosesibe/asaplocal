// ─────────────────────────────────────────────────────────────────────────
// AsapLocal — Prisma Schema
// PostgreSQL (Supabase) · pgcrypto for UUIDs · designed for RBAC + lead
// marketplace + dispatcher approval workflow.
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  PROVIDER
  DISPATCHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_VERIFICATION
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum PriceType {
  FIXED
  HOURLY
  QUOTE_ONLY
}

enum JobRequestStatus {
  OPEN          // just posted, being matched to providers
  MATCHING      // leads distributed to eligible providers
  QUOTED        // at least one quote received
  ASSIGNED      // customer accepted a quote / booked a provider
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum LeadStatus {
  AVAILABLE   // still open for purchase/claim by more providers
  LIMITED     // sold to max providers, no longer purchasable
  EXPIRED
  CLOSED      // job request cancelled/completed upstream
}

enum LeadAcquisitionType {
  PURCHASE              // paid per-lead via card
  SUBSCRIPTION_ALLOWANCE // consumed from monthly plan allowance
  CREDIT                // consumed from purchased lead-credit wallet
  CLAIM                 // free claim (e.g. promo / first-come within radius)
}

enum ProviderLeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum RefundRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RefundReason {
  OUT_OF_SERVICE_AREA
  DUPLICATE_LEAD
  SPAM_OR_FAKE
  UNRESPONSIVE_CUSTOMER
  WRONG_CATEGORY
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PaymentType {
  BOOKING_DEPOSIT
  BOOKING_FULL
  LEAD_PURCHASE
  LEAD_CREDIT_TOPUP
  SUBSCRIPTION
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  FLAGGED
  HIDDEN
}

enum ReportTargetType {
  LISTING
  REVIEW
  USER
  MESSAGE
  BOOKING
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum NotificationType {
  NEW_LEAD
  LEAD_CLAIMED
  QUOTE_RECEIVED
  QUOTE_ACCEPTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  PAYMENT_RECEIVED
  REFUND_PROCESSED
  SUBSCRIPTION_RENEWED
  VERIFICATION_UPDATE
  DISPATCHER_ASSIGNMENT
  APPROVAL_DECISION
  SYSTEM
}

enum ApprovalActionType {
  JOB_CREATE
  JOB_UPDATE
  JOB_DELETE
  JOB_ASSIGN_PROVIDER
  JOB_STATUS_OVERRIDE
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Core identity ───────────────────────────────────────────────────────

model User {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String        @unique
  emailVerified     DateTime?
  name              String?       // populated by OAuth providers (e.g. Google); not used for display — see Profile.firstName/lastName
  phone             String?
  passwordHash      String?       // null when using OAuth-only
  role              Role          @default(CUSTOMER)
  status            UserStatus    @default(PENDING_VERIFICATION)
  image             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lastLoginAt       DateTime?
  suspendedAt       DateTime?
  suspendedReason    String?

  profile           Profile?
  business          Business?               // present only when role = PROVIDER
  jobRequests       JobRequest[]             @relation("CustomerJobRequests")
  favourites        Favourite[]
  reviewsWritten    Review[]                 @relation("ReviewAuthor")
  bookingsAsCustomer Booking[]               @relation("CustomerBookings")
  payments          Payment[]
  notifications     Notification[]
  sentMessages      Message[]                @relation("MessageSender")
  conversations     ConversationParticipant[]
  reportsFiled      Report[]                 @relation("ReportsFiled")
  auditLogs         AuditLog[]               @relation("AuditActor")
  approvalRequestsMade     ApprovalRequest[]  @relation("ApprovalRequester")
  approvalRequestsReviewed ApprovalRequest[]  @relation("ApprovalReviewer")
  dispatcherAssignments    DispatcherAssignment[] @relation("DispatcherActor")
  accounts          Account[]
  sessions          Session[]

  @@index([role])
  @@index([status])
  @@index([email])
}

// Auth.js adapter tables
model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @db.Uuid
  firstName   String
  lastName    String
  avatarUrl   String?
  bio         String?  @db.Text
  addressLine String?
  city        String?
  postcode    String?
  country     String   @default("GB")
  lat         Decimal? @db.Decimal(9, 6)
  lng         Decimal? @db.Decimal(9, 6)
  timezone    String   @default("Europe/London")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
}

// ── Categories & Businesses ─────────────────────────────────────────────

model Category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @unique
  slug        String     @unique
  icon        String?
  description String?    @db.Text
  parentId    String?    @db.Uuid
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryChildren")
  services    Service[]
  jobRequests JobRequest[]

  @@index([parentId])
  @@index([slug])
}

model Business {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId            String              @unique @db.Uuid
  name               String
  slug               String              @unique
  description        String?             @db.Text
  logoUrl            String?
  coverImageUrl      String?
  phone              String?
  email              String?
  website            String?
  verificationStatus VerificationStatus  @default(UNVERIFIED)
  verifiedAt         DateTime?
  verificationDocsUrl String[]
  addressLine        String?
  city               String
  postcode           String?
  country            String              @default("GB")
  lat                Decimal             @db.Decimal(9, 6)
  lng                Decimal             @db.Decimal(9, 6)
  baseRadiusMiles     Int                @default(10)
  yearsInBusiness    Int?
  employeeCount      Int?
  insured            Boolean             @default(false)
  avgRating          Decimal             @default(0) @db.Decimal(2, 1)
  reviewCount        Int                 @default(0)
  completedJobsCount Int                 @default(0)
  responseRatePct    Decimal             @default(0) @db.Decimal(5, 2)
  avgResponseMins    Int?
  profileViews       Int                 @default(0)
  isFeatured         Boolean             @default(false)
  featuredUntil      DateTime?
  stripeAccountId    String?             // Stripe Connect (payouts)
  stripeCustomerId   String?             // Stripe Customer (billing)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  serviceAreas       ServiceArea[]
  services           Service[]
  subscription       Subscription?
  leadCreditWallet   LeadCreditWallet?
  leadAccesses       LeadAccess[]
  quotes             Quote[]
  bookings           Booking[]           @relation("ProviderBookings")
  reviews            Review[]
  favouritedBy       Favourite[]
  payments           Payment[]
  dispatcherAssignments DispatcherAssignment[] @relation("AssignedBusiness")

  @@index([city])
  @@index([verificationStatus])
  @@index([isFeatured])
  @@index([lat, lng])
}

model ServiceArea {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId   String   @db.Uuid
  city         String
  postcodePrefix String?
  lat          Decimal  @db.Decimal(9, 6)
  lng          Decimal  @db.Decimal(9, 6)
  radiusMiles  Int      @default(10)
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([lat, lng])
}

model Service {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId  String    @db.Uuid
  categoryId  String    @db.Uuid
  title       String
  description String?   @db.Text
  priceType   PriceType @default(QUOTE_ONLY)
  priceMinPence Int?
  priceMaxPence Int?
  durationMins Int?
  images      String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bookings Booking[]

  @@index([businessId])
  @@index([categoryId])
}

// ── Job requests & the lead marketplace ─────────────────────────────────
// Customer posts a JobRequest with no provider chosen. The platform fans it
// out as a Lead to eligible providers (category + radius). Providers acquire
// access via LeadAccess (purchase / subscription allowance / credit / claim)
// and track their own pipeline status independently of other providers.

model JobRequest {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId    String            @db.Uuid
  categoryId    String            @db.Uuid
  title         String
  description   String            @db.Text
  photos        String[]
  budgetMinPence Int?
  budgetMaxPence Int?
  preferredDate DateTime?
  flexibleDate  Boolean           @default(true)
  addressLine   String?
  city          String
  postcode      String?
  lat           Decimal           @db.Decimal(9, 6)
  lng           Decimal           @db.Decimal(9, 6)
  status        JobRequestStatus  @default(OPEN)
  aiSuggestedCategoryId String?   @db.Uuid
  aiCategoryConfidence  Decimal?  @db.Decimal(4, 3)
  maxLeadSales  Int               @default(5)   // cap on how many providers can acquire this lead
  leadPricePence Int              @default(1000) // computed at creation (£5–£20 band)
  expiresAt     DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer   User        @relation("CustomerJobRequests", fields: [customerId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  lead       Lead?
  quotes     Quote[]
  booking    Booking?
  conversations Conversation[]
  dispatcherAssignments DispatcherAssignment[]
  approvalRequests ApprovalRequest[]

  @@index([customerId])
  @@index([categoryId])
  @@index([status])
  @@index([city])
  @@index([lat, lng])
}

model Lead {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRequestId  String     @unique @db.Uuid
  status        LeadStatus @default(AVAILABLE)
  radiusMiles   Int        @default(15)
  salesCount    Int        @default(0)
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  jobRequest JobRequest   @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  accesses   LeadAccess[]

  @@index([status])
}

// One row per provider who has acquired (purchased/claimed) a given lead.
model LeadAccess {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId           String              @db.Uuid
  businessId       String              @db.Uuid
  acquisitionType  LeadAcquisitionType
  pricePaidPence   Int                 @default(0)
  creditsSpent     Int                 @default(0)
  status           ProviderLeadStatus  @default(NEW)
  contactedAt      DateTime?
  quotedAt         DateTime?
  wonAt            DateTime?
  lostAt           DateTime?
  lostReason       String?
  isRefunded       Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  lead             Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  business         Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  payment          Payment?
  refundRequest    RefundRequest?
  creditTransaction LeadCreditTransaction?

  @@unique([leadId, businessId]) // a provider can only acquire a given lead once
  @@index([businessId, status])
  @@index([leadId])
}

model RefundRequest {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadAccessId   String               @unique @db.Uuid
  requestedById  String               @db.Uuid
  reason         RefundReason
  details        String?              @db.Text
  status         RefundRequestStatus  @default(PENDING)
  refundAmountPence Int?
  reviewedById   String?              @db.Uuid
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime             @default(now())

  leadAccess LeadAccess @relation(fields: [leadAccessId], references: [id], onDelete: Cascade)

  @@index([status])
}

model LeadCreditWallet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId String   @unique @db.Uuid
  balance    Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  business     Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions LeadCreditTransaction[]
}

enum LeadCreditTxType {
  SUBSCRIPTION_GRANT
  TOPUP_PURCHASE
  SPEND
  REFUND
  ADMIN_ADJUSTMENT
}

model LeadCreditTransaction {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId     String            @db.Uuid
  type         LeadCreditTxType
  amount       Int               // positive = credit, negative = debit
  leadAccessId String?           @unique @db.Uuid
  description  String?
  createdAt    DateTime          @default(now())

  wallet     LeadCreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  leadAccess LeadAccess?      @relation(fields: [leadAccessId], references: [id], onDelete: SetNull)

  @@index([walletId])
}

// ── Quotes & Bookings ────────────────────────────────────────────────────

model Quote {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRequestId String      @db.Uuid
  businessId   String      @db.Uuid
  amountPence  Int
  message      String?     @db.Text
  validUntil   DateTime?
  status       QuoteStatus @default(SENT)
  aiGenerated  Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  jobRequest JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking    Booking?

  @@unique([jobRequestId, businessId])
  @@index([status])
}

model Booking {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId       String        @db.Uuid
  businessId       String        @db.Uuid
  serviceId        String?       @db.Uuid
  jobRequestId     String?       @unique @db.Uuid
  quoteId          String?       @unique @db.Uuid
  scheduledDate    DateTime
  status           BookingStatus @default(PENDING)
  totalAmountPence Int
  depositAmountPence Int?
  addressLine      String
  city             String
  postcode         String?
  notes            String?       @db.Text
  cancelledReason  String?
  cancelledAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer   User        @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  business   Business    @relation("ProviderBookings", fields: [businessId], references: [id], onDelete: Cascade)
  service    Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  jobRequest JobRequest? @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  quote      Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  payments   Payment[]
  review     Review?
  conversation Conversation?

  @@index([customerId])
  @@index([businessId])
  @@index([status])
  @@index([scheduledDate])
}

// ── Reviews & Favourites ─────────────────────────────────────────────────

model Review {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId       String       @unique @db.Uuid
  authorId        String       @db.Uuid
  businessId      String       @db.Uuid
  rating          Int          // 1-5
  comment         String?      @db.Text
  photos          String[]
  status          ReviewStatus @default(PUBLISHED)
  aiFlagged       Boolean      @default(false)
  aiFlagReason    String?
  providerResponse String?     @db.Text
  respondedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author   User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reports  Report[]

  @@index([businessId, status])
  @@index([rating])
}

model Favourite {
  customerId String   @db.Uuid
  businessId String   @db.Uuid
  createdAt  DateTime @default(now())

  customer User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@id([customerId, businessId])
  @@index([businessId])
}

// ── Messaging ─────────────────────────────────────────────────────────────

model Conversation {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRequestId String?   @db.Uuid
  bookingId    String?   @unique @db.Uuid
  lastMessageAt DateTime?
  createdAt    DateTime  @default(now())

  jobRequest   JobRequest? @relation(fields: [jobRequestId], references: [id], onDelete: SetNull)
  booking      Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([jobRequestId])
}

model ConversationParticipant {
  conversationId String    @db.Uuid
  userId         String    @db.Uuid
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @db.Uuid
  senderId       String   @db.Uuid
  body           String   @db.Text
  attachments    String[]
  readByUserIds  String[] @db.Uuid
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── Payments & Subscriptions ─────────────────────────────────────────────

model Payment {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String        @db.Uuid
  businessId            String?       @db.Uuid
  bookingId             String?       @db.Uuid
  leadAccessId          String?       @unique @db.Uuid
  type                  PaymentType
  status                PaymentStatus @default(PENDING)
  amountPence           Int
  currency              String        @default("gbp")
  refundedAmountPence   Int           @default(0)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  stripeInvoiceId       String?
  failureReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  booking    Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  leadAccess LeadAccess? @relation(fields: [leadAccessId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([businessId])
  @@index([status])
  @@index([type])
}

model Subscription {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessId           String              @unique @db.Uuid
  plan                 SubscriptionPlan    @default(FREE)
  status               SubscriptionStatus  @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?             @unique
  stripePriceId        String?
  monthlyLeadAllowance Int                 @default(0)
  leadAllowanceUsed    Int                 @default(0)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
}

// ── Notifications, Reports, Audit, Dispatcher approvals ──────────────────

model Notification {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String            @db.Uuid
  type      NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean           @default(false)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Report {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId   String           @db.Uuid
  targetType   ReportTargetType
  targetId     String           @db.Uuid
  reviewTarget String?          @db.Uuid // convenience FK when targetType = REVIEW
  reason       String
  details      String?          @db.Text
  status       ReportStatus     @default(OPEN)
  resolvedById String?          @db.Uuid
  resolvedAt   DateTime?
  resolutionNote String?
  createdAt    DateTime         @default(now())

  reporter     User    @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedReview Review? @relation(fields: [reviewTarget], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([targetType, targetId])
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @db.Uuid
  actorRole  Role?
  action     String   // e.g. "user.suspend", "lead.refund.approve"
  targetType String
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// Dispatchers can act on job requests (assign to a provider, update, delete)
// but every mutating action is recorded as an ApprovalRequest that an Admin
// must approve before it takes effect (except read-only tracking/assignment
// proposals, which is why `payload` stores the *proposed* change).
model ApprovalRequest {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestedById String                 @db.Uuid
  actionType    ApprovalActionType
  jobRequestId  String?                @db.Uuid
  payload       Json                   // proposed change, e.g. { assignBusinessId, note }
  status        ApprovalRequestStatus  @default(PENDING)
  reviewedById  String?                @db.Uuid
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime               @default(now())

  requestedBy User        @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  jobRequest  JobRequest? @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([requestedById])
}

// Confirmed record of a dispatcher sending a job to a specific provider
// (created once the corresponding ApprovalRequest is APPROVED).
model DispatcherAssignment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRequestId      String   @db.Uuid
  dispatcherId      String   @db.Uuid
  assignedBusinessId String  @db.Uuid
  note              String?
  approvalRequestId String?  @unique @db.Uuid
  createdAt         DateTime @default(now())

  jobRequest       JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  dispatcher       User       @relation("DispatcherActor", fields: [dispatcherId], references: [id], onDelete: Cascade)
  assignedBusiness Business   @relation("AssignedBusiness", fields: [assignedBusinessId], references: [id], onDelete: Cascade)

  @@index([jobRequestId])
  @@index([dispatcherId])
}
