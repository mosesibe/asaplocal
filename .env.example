# ── Database (Supabase Postgres) ─────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asaplocal?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/asaplocal?schema=public"

# ── Auth.js ───────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand--base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_PREMIUM_MONTHLY="price_xxx"
STRIPE_LEAD_CREDIT_PACK_SMALL="price_xxx"
STRIPE_LEAD_CREDIT_PACK_LARGE="price_xxx"

# ── AWS S3 ────────────────────────────────────────────────────
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="asaplocal-uploads"

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=""

# ── Messaging (Pusher) ────────────────────────────────────────
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="AsapLocal <noreply@asaplocal.app>"

# ── AI (OpenAI) ───────────────────────────────────────────────
OPENAI_API_KEY=""

# ── Redis (rate limiting / caching, e.g. Upstash) ─────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── App URLs (used cross-app for links in emails/redirects) ───
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_PROVIDER_URL="http://localhost:3001"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# ── Lead marketplace tuning ────────────────────────────────────
LEAD_DEFAULT_RADIUS_MILES=15
LEAD_PRICE_MIN_PENCE=500
LEAD_PRICE_MAX_PENCE=2000
